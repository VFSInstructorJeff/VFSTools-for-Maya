        -imageOverlayLabel "PresUV" 
        -overlayLabelColor 1 0.7255 0 
        -overlayLabelBackColor 0 0 0 0.5 
        -image "UVTkUV.png" 
        -image1 "UVTkUV.png" 
        -style "iconOnly" 
        -marginWidth 0

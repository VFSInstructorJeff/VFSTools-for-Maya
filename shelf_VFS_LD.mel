        -command "from maya import cmds\n\n\nIsPresUVsOn = cmds.manipMoveContext('Move', query=True, preserveUV=True)\n\nif (IsPresUVsOn):\n    cmds.manipMoveContext('Move', edit=True, preserveUV=False)\n    cmds.inViewMessage(amg='Preserve UVs is <hl>OFF</hl>.', pos='topCenter', fade=True)\nelse:\n    cmds.manipMoveContext('Move', edit=True, preserveUV=True)\n    cmds.inViewMessage(amg='Preserve UVs is <hl>ON</hl>.', pos='topCenter', fade=True)" 
        -sourceType "python" 
